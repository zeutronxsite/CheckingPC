local logCount = 0
local function addLog(text, type)
    logCount = logCount + 1
    local logFrame = Instance.new("Frame")
    logFrame.Size = UDim2.new(1, -10, 0, 25)
    logFrame.BackgroundTransparency = 1
    logFrame.LayoutOrder = logCount
    logFrame.Parent = logScroll

    local icon = ""
    local color = Color3.fromRGB(200, 200, 200)
    
    if type == "success" then
        icon = "<font color='rgb(0,255,100)'>[✓]</font> "
        color = Color3.fromRGB(200, 200, 200)
    elseif type == "error" then
        icon = "<font color='rgb(255,50,50)'>[✗]</font> "
        color = Color3.fromRGB(200, 200, 200)
    elseif type == "info" then
        icon = "<font color='rgb(0,150,255)'>[i]</font> "
        color = Color3.fromRGB(200, 200, 200)
    elseif type == "warn" then
        icon = "<font color='rgb(255,200,0)'>[!]</font> "
        color = Color3.fromRGB(200, 200, 200)
    end

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = icon .. text
    label.Font = Enum.Font.Code
    label.TextSize = 14
    label.TextColor3 = color
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.RichText = true
    label.Parent = logFrame
    
    -- Scroll to bottom
    logScroll.CanvasPosition = Vector2.new(0, logScroll.AbsoluteCanvasSize.Y)
end

local function updateProgress(percent)
    percent = math.clamp(percent, 0, 100)
    progressFill.Size = UDim2.new(percent / 100, 0, 1, 0)
end

