end

local function showError()
    addLog("Critical Error Detected!", "error")
    updateProgress(0)
    checkingLabel.Text = "Failed"
    checkingLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
    statusDot.BackgroundColor3 = Color3.fromRGB(255, 50, 50) -- Red
    
    btnRetry.Visible = true
end

