-- Main Sequence Function
function executeCheckSequence()
    -- Reset UI State
    logScroll:ClearAllChildren()
    updateProgress(0)
    checkingLabel.Text = "Checking..."
    checkingLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    statusDot.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    btnContinue.Visible = false
    btnRetry.Visible = false

    addLog("Initializing ZETHUB Core...", "info")
    updateProgress(5)
    task.wait(1)

    addLog("Verifying Device Environment...", "info")
    updateProgress(15)
    task.wait(1)
    addLog("Device: " .. deviceName, "success")

    addLog("Connecting to Server...", "info")
    updateProgress(25)
    task.wait(1.5)
    addLog("Connection Stable.", "success")

    -- Stage: Anti-Cheat
    addLog("Bypassing Anti-Cheat V1...", "warn")
    updateProgress(40)
    task.wait(2)
    local success1 = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/c00lhaxOFFICAL/GrayScriptsAntiCheatRemoverV2LITE/refs/heads/main/GrayGrayGray"))()
    end)
    if success1 then addLog("Anti-Cheat V1 Bypassed", "success") else addLog("Anti-Cheat V1 Failed", "error") end
    updateProgress(50)
    task.wait(1)

    addLog("Bypassing Anti-Cheat V2...", "warn")
    updateProgress(60)
    task.wait(2)
    local success2 = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/c00lhaxOFFICAL/GrayScriptsAntiCheatRemoverV2PLUS/refs/heads/main/V2PLUS"))()
    end)
    if success2 then addLog("Anti-Cheat V2 Bypassed", "success") else addLog("Anti-Cheat V2 Failed", "error") end
    updateProgress(70)
    task.wait(1)

    -- Stage: Tools
    addLog("[Attached] Infinite Yield...", "info")
    updateProgress(80)
    task.wait(2)
    local iyUrl = isMobile and "https://rawscripts.net/raw/Universal-Script-Infinite-Yield-Bypass-Anticheat-open-source-194150" or "https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source"
    pcall(function() loadstring(game:HttpGet(iyUrl))() end)
    addLog("Infinite Yield Loaded", "success")
    updateProgress(90)
    task.wait(1)

    -- Stage: Main Hub
    addLog("Loading ZETHUB Main Core...", "info")
    updateProgress(95)
    task.wait(2)
    local mainSuccess = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Zyptrue/ZETHUB/refs/heads/main/Main%20Script"))()
    end)
    
    if mainSuccess then
        addLog("ZETHUB Core Loaded Successfully", "success")
        finishLoading()
    else
        showError()
    end
end

-- Start the sequence
task.spawn(executeCheckSequence)
